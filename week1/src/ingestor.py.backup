# src/ingestor.py
import os
import re
import quopri
import base64
from pathlib import Path
from email import policy
from email.parser import BytesParser

def ingest_all_mhtml(input_dir, output_dir):
    """
    Extract HTML from MHTML files and save as HTML files
    MHTML must be parsed as email multipart message
    """
    input_path = Path(input_dir)
    output_path = Path(output_dir)
    
    # Create output directory if it doesn't exist (idempotency)
    output_path.mkdir(parents=True, exist_ok=True)
    
    # Check if input directory exists
    if not input_path.exists():
        print(f"Warning: Input directory '{input_dir}' does not exist.")
        return
    
    # Find all .mhtml files
    mhtml_files = list(input_path.glob("*.mhtml")) + list(input_path.glob("*.mht"))
    
    if not mhtml_files:
        print(f"Warning: No .mhtml files found in '{input_dir}'.")
        return
    
    print("🥉 Bronze:...")
    
    extracted = 0
    failed = 0
    total = len(mhtml_files)
    
    for mhtml_path in mhtml_files:
        try:
            # Read the MHTML file as binary
            with open(mhtml_path, 'rb') as f:
                mhtml_data = f.read()
            
            # Parse as email multipart message (THIS IS CRITICAL for MHTML)
            msg = BytesParser(policy=policy.default).parsebytes(mhtml_data)
            
            html_content = None
            
            # Walk through all parts of the multipart message
            for part in msg.walk():
                content_type = part.get_content_type()
                
                # Look for HTML content
                if content_type == 'text/html':
                    payload = part.get_payload()
                    
                    # Get encoding type (quoted-printable is common in MHTML)
                    encoding = part.get('Content-Transfer-Encoding', '').lower()
                    
                    if encoding == 'quoted-printable':
                        # Decode quoted-printable string
                        if isinstance(payload, str):
                            payload = payload.encode('utf-8')
                        html_content = quopri.decodestring(payload).decode('utf-8', errors='replace')
                    elif encoding == 'base64':
                        # Decode base64
                        if isinstance(payload, str):
                            payload = payload.encode('utf-8')
                        html_content = base64.b64decode(payload).decode('utf-8', errors='replace')
                    else:
                        # Regular content
                        if isinstance(payload, bytes):
                            html_content = payload.decode('utf-8', errors='replace')
                        else:
                            html_content = payload
                    
                    break  # Found HTML, stop searching
            
            # If still no HTML, try to extract from raw content
            if html_content is None:
                # Search for HTML between html tags
                text_content = str(msg)
                html_match = re.search(r'<html.*?>.*?</html>', text_content, re.IGNORECASE | re.DOTALL)
                if html_match:
                    html_content = html_match.group(0)
                else:
                    print(f"⚠️ No HTML content found in: {mhtml_path.name}")
                    failed += 1
                    continue
            
            # Save extracted HTML
            output_file = output_path / f"{mhtml_path.stem}.html"
            with open(output_file, 'w', encoding='utf-8') as f:
                f.write(html_content)
            
            print(f"✅ Extracted: {mhtml_path.name}")
            extracted += 1
            
        except Exception as e:
            print(f"⚠️ No HTML content found in: {mhtml_path.name}")
            failed += 1
    
    print(f"\n📊 Bronze Summary:")
    print(f"Total: {total} | Extracted: {extracted} | Failed: {failed}")

if __name__ == "__main__":
    ingest_all_mhtml("data/0_source", "data/1_bronze")